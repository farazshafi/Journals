<script>
  const navItems = document.querySelectorAll(".nav-item");

  navItems.forEach((item) => {
    item.addEventListener("click", () => {
      const targetTab = item.getAttribute("data-tab");

      // Hide all right-side tab contents
      document
        .querySelectorAll('[id$="-right"]')
        .forEach((el) => el.classList.remove("active"));

      // Show corresponding right-side content
      const rightTab = document.getElementById(`tab-${targetTab}-right`);
      if (rightTab) rightTab.classList.add("active");

      // Handle Journeys Mode (Hide background and notebook, show image)
      const outer = document.querySelector(".scrapbook-outer");
      const appContainer = document.querySelector(".app-container");
      if (outer) {
        if (targetTab === "journeys") {
          outer.classList.add("journeys-mode");
          if (appContainer) appContainer.classList.add("no-wood-bg");
        } else {
          outer.classList.remove("journeys-mode");
          if (appContainer) appContainer.classList.remove("no-wood-bg");
        }
      }
    });
  });

  // Initial check on load
  document.addEventListener("DOMContentLoaded", () => {
    const activeNav = document.querySelector(".nav-item.active");
    if (activeNav) {
      const targetTab = activeNav.getAttribute("data-tab");
      const outer = document.querySelector(".scrapbook-outer");
      const appContainer = document.querySelector(".app-container");
      if (outer && targetTab === "journeys") {
        outer.classList.add("journeys-mode");
        if (appContainer) appContainer.classList.add("no-wood-bg");
      }
    }
  });

  // Random memory shuffle
  const memories = [
    {
      date: "15 AUG 2024 · Tosh, Himachal Pradesh",
      text: '"Sat for three hours on a rooftop. No signal. No plans. Just mountains."',
      tags: ["#tosh", "#himachal"],
    },
    {
      date: "22 OCT 2024 · Somewhere in Himachal",
      text: '"The mist was so thick you could write your name in it. I wrote nothing."',
      tags: ["#mountains", "#mist"],
    },
    {
      date: "03 MAY 2024 · Kheerganga Summit",
      text: '"Reached the top at sunset. The valley below glowed like a bowl of fire."',
      tags: ["#kheerganga", "#trekking"],
    },
    {
      date: "12 JAN 2024 · Manali, HP",
      text: '"Snow fell all night. By morning, the world was new again."',
      tags: ["#manali", "#snowfall"],
    },
  ];

  const shuffleBtn = document.getElementById("shuffle-btn");
  if (shuffleBtn) {
    shuffleBtn.addEventListener("click", () => {
      const mem = memories[Math.floor(Math.random() * memories.length)];
      const card = shuffleBtn.closest(".random-memory-card");
      if (card) {
        const dateEl = card.querySelector(".random-date");
        const textEl = card.querySelector(".random-text");
        const tagRow = card.querySelector(".random-tag-row");
        if (dateEl) dateEl.textContent = mem.date;
        if (textEl) textEl.textContent = mem.text;
        if (tagRow)
          tagRow.innerHTML = mem.tags
            .map((t) => `<span class="tag-pill small">${t}</span>`)
            .join("");
      }
    });
  }
</script>

<style>
  /* ==================
     SCRAPBOOK OUTER
     ================== */
  .scrapbook-outer {
    position: relative;
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding-bottom: 6rem; /* Room for the floating tickets */
    min-height: 80vh;
    justify-content: center;
  }

  /* Journeys Mode: Hide everything else */
  .scrapbook-outer.journeys-mode .bg-map,
  .scrapbook-outer.journeys-mode .bg-postcard,
  .scrapbook-outer.journeys-mode .bg-compass,
  .scrapbook-outer.journeys-mode .travel-ticket,
  .scrapbook-outer.journeys-mode .notebook-spread {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    position: absolute; /* Take out of flow */
  }

  .journeys-only-container {
    display: none;
    width: 100%;
    max-width: 800px;
    z-index: 20;
    animation: fadeIn 0.8s ease-out forwards;
  }

  .scrapbook-outer.journeys-mode .journeys-only-container {
    display: flex;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    max-width: none;
    background-color: #000;
    z-index: 1000; /* Full screen overlay */
    justify-content: center;
    align-items: center;
  }

  .journeys-image {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Fill the whole screen */
    filter: brightness(0.8);
  }

  /* Allow clicking back to other tabs by showing a close button or just relying on sidebar? 
     Actually, if it's full width/height fixed, the sidebar is hidden. 
     The user might want it to be behind the sidebar? */
  .scrapbook-outer.journeys-mode .journeys-only-container {
    left: 350px; /* Stay to the right of the sidebar */
    width: calc(100vw - 350px);
  }

  @media (max-width: 1023px) {
    .scrapbook-outer.journeys-mode .journeys-only-container {
      left: 0;
      width: 100vw;
      top: 280px; /* Below mobile sidebar */
      height: calc(100vh - 280px);
    }
  }

  .journeys-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.6);
  }

  /* Global background override for Journeys mode */
  :global(.app-container.no-wood-bg) {
    background-color: #000 !important;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ==================
     BG DECORATIVE ITEMS
     ================== */
  .bg-map {
    position: absolute;
    top: -6%;
    right: -12%;
    width: 72%;
    height: 55%;
    background-image: url("/assets/vintage_map.png");
    background-size: cover;
    background-position: top center;
    opacity: 0.65;
    box-shadow: 5px 15px 35px rgba(0, 0, 0, 0.6);
    transform: rotate(3deg);
    z-index: 0;
    border-radius: 4px;
    filter: sepia(0.3) brightness(0.85);
  }

  .bg-postcard {
    position: absolute;
    top: -9%;
    right: -4%;
    width: 200px;
    height: 155px;
    background-color: #ede8da;
    background-image: url("/assets/paper_texture.png");
    background-size: cover;
    color: var(--color-ink);
    padding: 1rem;
    box-shadow: 3px 8px 20px rgba(0, 0, 0, 0.5);
    transform: rotate(-13deg);
    z-index: 2;
    border-radius: 2px;
  }

  .postcard-header {
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-ink-faded);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .postcard-divider {
    width: 100%;
    height: 1px;
    background: rgba(0, 0, 0, 0.15);
    margin-bottom: 0.5rem;
  }

  .postcard-text {
    font-size: 1.6rem;
    line-height: 1.2;
    color: var(--color-ink);
  }

  /* Postcard stamp area (CSS only) */
  .bg-postcard::before {
    content: "";
    position: absolute;
    top: 12px;
    right: 12px;
    width: 35px;
    height: 42px;
    border: 2px dotted rgba(0, 0, 0, 0.3);
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 4px,
      rgba(0, 0, 0, 0.07) 4px,
      rgba(0, 0, 0, 0.07) 8px
    );
  }

  /* Compass */
  .bg-compass {
    position: absolute;
    bottom: -2%;
    right: -10%;
    width: 130px;
    height: 130px;
    background: radial-gradient(
      circle at 35% 35%,
      #f5e6b8 0%,
      #c8a265 30%,
      #7a5230 65%,
      #2c1a0e 100%
    );
    box-shadow:
      10px 20px 40px rgba(0, 0, 0, 0.7),
      inset 2px 2px 6px rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    transform: rotate(15deg);
    z-index: 10;
    border: 6px solid #3d2f1f;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s ease;
  }

  .bg-compass:hover {
    transform: rotate(30deg) scale(1.05);
  }

  .compass-cardinal {
    position: absolute;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 800;
    color: #1c0f05;
  }

  .compass-cardinal.n {
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .compass-cardinal.s {
    bottom: 5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .compass-cardinal.e {
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
  }
  .compass-cardinal.w {
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
  }

  .bg-compass-needle {
    position: absolute;
    width: 5px;
    height: 70px;
    background: linear-gradient(to bottom, #c73535 50%, #444 50%);
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
    animation: compass-drift 6s ease-in-out infinite alternate;
  }

  .compass-center-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    background: #c8a265;
    border-radius: 50%;
    border: 1px solid #3d2f1f;
    z-index: 1;
  }

  @keyframes compass-drift {
    0% {
      transform: rotate(42deg);
    }
    30% {
      transform: rotate(38deg);
    }
    70% {
      transform: rotate(46deg);
    }
    100% {
      transform: rotate(40deg);
    }
  }

  /* Travel Tickets */
  .travel-ticket {
    position: absolute;
    bottom: -4%;
    left: 50%;
    transform: translateX(-70%) rotate(-2deg);
    display: flex;
    gap: 4px;
    z-index: 6;
    filter: sepia(0.4) brightness(0.85);
  }

  .ticket-half {
    width: 160px;
    padding: 1rem;
    background-color: #e8dcc4;
    background-image: url("/assets/paper_texture.png");
    background-size: cover;
    color: var(--color-ink);
    box-shadow: 2px 5px 15px rgba(0, 0, 0, 0.3);
    position: relative;
    overflow: hidden;
  }

  .ticket-half::before {
    content: "";
    position: absolute;
    right: -8px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    background: radial-gradient(
      circle,
      rgba(18, 11, 8, 0.6) 50%,
      transparent 50%
    );
  }

  .ticket-half.right-ticket::before {
    left: -8px;
    right: auto;
  }

  .ticket-label {
    font-family: var(--font-sans);
    font-size: 0.45rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    opacity: 0.6;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .ticket-content {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    line-height: 1.6;
    color: var(--color-ink);
  }

  .ticket-stamp {
    margin-top: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    opacity: 0.5;
  }

  .ticket-barcode {
    margin-top: 0.7rem;
    display: flex;
    gap: 2px;
  }

  .ticket-barcode span {
    display: block;
    height: 28px;
    flex: 1;
    background: var(--color-ink);
    opacity: 0.7;
  }

  .ticket-barcode span:nth-child(even) {
    width: 3px;
    flex: 1.5;
    opacity: 0.4;
  }

  /* ==================
     NOTEBOOK SPREAD
     ================== */
  .notebook-spread {
    position: relative;
    z-index: 5;
    width: 100%;
    background-image: url("/assets/paper_texture.png");
    background-size: cover;
    background-color: var(--color-paper);
    box-shadow:
      8px 25px 55px rgba(0, 0, 0, 0.65),
      -2px 10px 20px rgba(0, 0, 0, 0.25);
    border-radius: 6px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 500px;
    overflow: hidden;
    transition:
      box-shadow 0.5s ease,
      opacity 0.4s ease;
  }

  .notebook-spread.hidden-for-journeys {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .notebook-spread:hover {
    box-shadow:
      10px 30px 70px rgba(0, 0, 0, 0.75),
      -2px 12px 25px rgba(0, 0, 0, 0.3);
  }

  /* Center crease */
  .notebook-spread::after {
    content: "";
    position: absolute;
    top: 0;
    left: calc(50% - 12px);
    width: 24px;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.06) 0%,
      rgba(0, 0, 0, 0.12) 35%,
      rgba(0, 0, 0, 0.2) 50%,
      rgba(0, 0, 0, 0.12) 65%,
      rgba(0, 0, 0, 0.06) 100%
    );
    z-index: 10;
    pointer-events: none;
  }

  /* Notebook Rings */
  .notebook-rings {
    position: absolute;
    top: 6%;
    bottom: 6%;
    left: calc(50% - 10px);
    width: 20px;
    z-index: 11;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    pointer-events: none;
  }

  .notebook-ring {
    width: 20px;
    height: 7px;
    background: linear-gradient(to bottom, #d5d5d5, #777, #444, #999);
    border-radius: 4px;
    box-shadow:
      0 3px 6px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
    transform: rotate(-2deg);
  }

  /* Paper Clip */
  .paper-clip {
    position: absolute;
    top: 1.5rem;
    right: 3.5rem;
    width: 24px;
    height: 60px;
    border: 2.5px solid #8e8e8e;
    border-radius: 14px;
    background: transparent;
    transform: rotate(-12deg);
    z-index: 12;
    box-shadow: 2px 3px 8px rgba(0, 0, 0, 0.2);
  }

  .paper-clip::before {
    content: "";
    position: absolute;
    top: 7px;
    left: 3px;
    right: 3px;
    bottom: 7px;
    border: 2px solid #aaa;
    border-radius: 10px;
  }

  /* ==================
     NOTEBOOK PAGES
     ================== */
  .notebook-page {
    padding: 2.5rem 2.5rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    position: relative;
    min-height: 500px;
  }

  .notebook-page.left-page {
    border-right: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: inset -15px 0 25px rgba(0, 0, 0, 0.04);
  }

  .notebook-page.right-page {
    box-shadow: inset 15px 0 25px rgba(0, 0, 0, 0.04);
    padding-left: 3rem;
  }

  /* ==================
     TAB CONTENT
     ================== */
  .tab-content {
    display: none;
    opacity: 0;
    transform: translateY(8px);
    height: 100%;
    flex-direction: column;
    gap: 1.2rem;
  }

  .tab-content.active {
    display: flex;
    animation: tabFadeIn 0.5s var(--ease-vintage) forwards;
  }

  @keyframes tabFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ==================
     HOME TAB
     ================== */
  .left-note-card {
    background-color: rgba(255, 255, 255, 0.65);
    background-image: url("/assets/paper_texture.png");
    background-size: cover;
