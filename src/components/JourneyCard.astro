---
interface Props {
    image: string;
    title: string;
    date: string;
    days: number;
    regions: number;
    pages: number;
    slotNum?: string;
}

const { image, title, date, days, regions, pages, slotNum } = Astro.props;
---

<div class="journey-card">
    <!-- Card Base / Background -->
    <div class="card-inner">
        {slotNum && <span class="slot-label">{slotNum}</span>}
        <!-- Slot #1: Main Image -->
        <div class="card-image-wrapper">
            <img src={image} alt={title} class="main-image" />
        </div>

        <!-- Content Section -->
        <div class="card-details">
            <div class="title-section">
                <h3 class="traveled-title">{title}</h3>
                <p class="traveled-date">{date}</p>
            </div>

            <!-- Stats Section -->
            <div class="stats-row">
                <div class="stat-item" title="Duration">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="stat-icon"
                        ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                            x1="8"
                            y1="2"
                            x2="8"
                            y2="6"></line><line x1="3" y1="10" x2="21" y2="10"
                        ></line></svg
                    >
                    <span>{days}-days</span>
                </div>
                <div class="stat-item" title="Regions">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="stat-icon"
                        ><path
                            d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                        ></path><circle cx="12" cy="10" r="3"></circle></svg
                    >
                    <span>{regions}-regions</span>
                </div>
                <div class="stat-item" title="Pages">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="stat-icon"
                        ><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path
                            d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
                        ></path></svg
                    >
                    <span>{pages}-pages</span>
                </div>
            </div>

            <!-- Action Button -->
            <button class="read-journal-btn">
                <span>Read Journal</span>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="arrow-icon"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
            </button>
        </div>
    </div>
</div>

<style>
    .journey-card {
        position: relative;
        width: 320px;
        height: 460px;
        padding: 1.5rem;
        background-image: url("/assets/card.webp");
        background-size: 100% 100%;
        background-repeat: no-repeat;
        display: flex;
        flex-direction: column;
        /* Premium deep shadow */
        box-shadow:
            0 25px 60px rgba(0, 0, 0, 0.6),
            0 5px 15px rgba(0, 0, 0, 0.4);
        transition:
            transform 0.4s var(--ease-vintage),
            box-shadow 0.4s var(--ease-vintage);
        cursor: pointer;
    }

    .journey-card:hover {
        transform: translateY(-12px) scale(1.02);
        box-shadow:
            0 40px 80px rgba(0, 0, 0, 0.8),
            0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .card-inner {
        height: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 0.25rem;
    }

    .slot-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--color-ink-faded);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        opacity: 0.9;
    }

    /* Large Image Area */
    .card-image-wrapper {
        width: 100%;
        height: 200px;
        overflow: hidden;
        border-radius: 4px;
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(0, 0, 0, 0.15);
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s var(--ease-vintage);
    }

    .journey-card:hover .main-image {
        transform: scale(1.15);
    }

    .card-details {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 0.5rem 0.25rem 0;
    }

    .traveled-title {
        font-family: var(--font-handwritten);
        font-size: 2rem;
        color: var(--color-ink);
        margin: 0;
        line-height: 1.1;
    }

    .traveled-date {
        font-family: var(--font-handwritten);
        font-size: 0.85rem;
        color: var(--color-ink-faded);
        letter-spacing: 0.1em;
        margin-top: 0.3rem;
    }

    .stats-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem 0;
        border-top: 1px dashed rgba(0, 0, 0, 0.15);
        border-bottom: 1px dashed rgba(0, 0, 0, 0.15);
        margin: 0.8rem 0;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        flex: 1;
    }

    .stat-icon {
        color: var(--color-brass-dark);
    }

    .stat-item span {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--color-ink);
        opacity: 0.9;
    }

    .read-journal-btn {
        width: 100%;
        background: var(--color-ink);
        color: var(--color-paper);
        border: none;
        padding: 0.85rem;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition:
            background 0.3s ease,
            transform 0.2s ease;
    }

    .read-journal-btn:hover {
        background: #000;
        transform: scale(1.02);
    }

    .arrow-icon {
        transition: transform 0.3s var(--ease-vintage);
    }

    .read-journal-btn:hover .arrow-icon {
        transform: translateX(5px);
    }
</style>
