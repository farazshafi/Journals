---

<aside class="sidebar-wrapper">
  <div class="sidebar-content">
    <!-- Brand / Logo Header -->
    <div class="brand-section">
      <div class="mountain-doodle">
        <svg
          viewBox="0 0 100 45"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <!-- Mountain peak 1 -->
          <path d="M15 40 L35 15 L50 32 L68 8 L90 40 Z"></path>
          <!-- Mountain peak 2 overlapping -->
          <path d="M30 40 L48 24 L60 35"></path>
          <!-- Mountain details/snowcap lines -->
          <path d="M31 20 L35 24 M35 15 L32 22 L38 23"></path>
          <path d="M63 15 L68 8 L65 17 L72 18"></path>
          <!-- Stars -->
          <path
            d="M48 6 L50 10 L48 14 L46 10 Z"
            fill="currentColor"
            stroke="none"></path>
          <path d="M22 10 Q24 10 24 8 Q24 10 26 10 Q24 10 24 12 Q24 10 22 10"
          ></path>
          <path d="M78 12 Q79 12 79 11 Q79 12 80 12 Q79 12 79 13 Q79 12 78 12"
          ></path>
        </svg>
      </div>
      <h1 class="logo-title">Wanderlust.</h1>
      <p class="logo-subtitle">MEMORIES. ROADS. STORIES.</p>
    </div>

    <!-- Navigation Menu -->
    <nav class="navigation-menu">
      <ul>
        <li>
          <button class="nav-item active" data-tab="journeys">
            <span class="nav-icon">
              <!-- Map Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"
                ></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line
                  x1="15"
                  y1="6"
                  x2="15"
                  y2="21"></line></svg
              >
            </span>
            <span class="nav-text">Journeys</span>
          </button>
        </li>
        <li>
          <button class="nav-item" data-tab="tags">
            <span class="nav-icon">
              <!-- Tag Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"
                ></path><path d="M7 7h.01"></path></svg
              >
            </span>
            <span class="nav-text">Tags</span>
          </button>
        </li>
        <li>
          <button class="nav-item" data-tab="random">
            <span class="nav-icon">
              <!-- Die Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
                ></rect><path d="M12 12h.01M8 8h.01M16 16h.01M8 16h.01M16 8h.01"
                ></path></svg
              >
            </span>
            <span class="nav-text">Random Memory</span>
          </button>
        </li>
      </ul>
    </nav>

    <!-- Footer Quote & Socials -->
    <div class="sidebar-footer">
      <div class="quote-container">
        <p class="quote-text">"Collect moments, not things."</p>
        <svg
          class="quote-underline"
          viewBox="0 0 200 10"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M5 5 Q60 2 110 5 T195 4" stroke-linecap="round"></path>
          <path d="M25 8 Q90 5 160 7" stroke-linecap="round"></path>
        </svg>
      </div>

      <div class="social-links">
        <a
          href="https://instagram.com"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
        <a
          href="https://spotify.com"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="Spotify"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="10"></circle><path
              d="M8 11.5c2.5-1 5.5-.5 8 1M9 15c2-1 4.5-1 6.5 0M7 8c3-1.5 7-1.5 10 0"
            ></path></svg
          >
        </a>
        <a
          href="https://maps.google.com"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="Location Pin"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
        </a>
      </div>

      <!-- Mute Toggle Button -->
      <div class="audio-control">
        <button id="mute-toggle" class="mute-btn" title="Toggle Sound">
          <span class="icon-on">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
              ></polygon><path
                d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"
              ></path></svg
            >
          </span>
          <span class="icon-off" style="display: none;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
              ></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line
                x1="17"
                y1="9"
                x2="23"
                y2="15"></line></svg
            >
          </span>
        </button>
      </div>
    </div>
  </div>
</aside>

<!-- Audio Elements -->
<audio id="bg-wind-audio" src="/assets/sounds/wind.mp3" loop></audio>
<audio id="page-flip-audio" src="/assets/sounds/page%20flip.mp3"></audio>

<script>
  // Audio Handling
  const windAudio = document.getElementById("bg-wind-audio");
  const flipAudio = document.getElementById("page-flip-audio");
  const muteBtn = document.getElementById("mute-toggle");
  const iconOn = muteBtn?.querySelector(".icon-on");
  const iconOff = muteBtn?.querySelector(".icon-off");

  let isMuted = localStorage.getItem("audioMuted") === "true";
  let hasInteracted = false;

  function updateMuteUI() {
    if (iconOn && iconOff) {
      iconOn.style.display = isMuted ? "none" : "block";
      iconOff.style.display = isMuted ? "block" : "none";
    }
    if (windAudio) windAudio.muted = isMuted;
    if (flipAudio) flipAudio.muted = isMuted;
  }

  function playFlipSound() {
    if (!isMuted && flipAudio) {
      flipAudio.currentTime = 0;
      flipAudio.play().catch((e) => console.log("Audio play failed:", e));
    }
  }

  function startBackgroundAudio() {
    if (!hasInteracted && windAudio) {
      hasInteracted = true;
      windAudio.volume = 0;
      windAudio
        .play()
        .then(() => {
          // Subtle fade in
          let vol = 0;
          const interval = setInterval(() => {
            if (vol < 0.3) {
              vol += 0.05;
              windAudio.volume = vol;
            } else {
              clearInterval(interval);
            }
          }, 200);
        })
        .catch((e) => console.log("Background audio failed:", e));
    }
  }

  // Initialize UI
  updateMuteUI();

  muteBtn?.addEventListener("click", () => {
    isMuted = !isMuted;
    localStorage.setItem("audioMuted", isMuted);
    updateMuteUI();
    // Ensure background audio is initialized/played even if muted
    // so it's ready as soon as the user unmutes.
    startBackgroundAudio();
  });

  // Tab switching click handling
  const navItems = document.querySelectorAll(".nav-item");
  const tabContents = document.querySelectorAll(".tab-content");

  navItems.forEach((item) => {
    item.addEventListener("click", () => {
      startBackgroundAudio();
      playFlipSound();

      // 1. Remove active class from all items
      navItems.forEach((i) => i.classList.remove("active"));
      // 2. Add active class to clicked item
      item.classList.add("active");

      // 3. Get targeted tab
      const targetTab = item.getAttribute("data-tab");

      // 4. Update tab content visibility
      tabContents.forEach((content) => {
        content.classList.remove("active");
        if (content.id === `tab-${targetTab}`) {
          content.classList.add("active");
        }
      });
    });
  });

  // Start audio on first user click anywhere if not muted
  document.addEventListener(
    "click",
    () => {
      startBackgroundAudio();
    },
    { once: true },
  );
</script>

<style>
  .sidebar-wrapper {
    background-color: var(--color-overlay-sidebar);
    border-right: 1px solid rgba(189, 162, 116, 0.15);
    height: 100vh;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
    overflow-y: auto;
  }

  .sidebar-content {
    padding: 3rem 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
  }

  /* Logo / Brand */
  .brand-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .mountain-doodle {
    width: 80px;
    color: var(--color-brass-light);
    opacity: 0.85;
    margin-bottom: 0.5rem;
  }

  .logo-title {
    font-family: var(--font-script);
    font-size: 3rem;
    font-weight: 400;
    line-height: 1;
    color: #fff;
    letter-spacing: -1px;
    margin-bottom: 0.25rem;
  }

  .logo-subtitle {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--color-brass-light);
    opacity: 0.8;
  }

  /* Navigation */
  .navigation-menu {
    width: 100%;
  }

  .navigation-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
  }

  .navigation-menu li {
    width: 100%;
  }

  .nav-item {
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
    transition: color 0.3s ease;
  }

  /* The Brush highlight overlay */
  .nav-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      rgba(189, 162, 116, 0.25) 0%,
      rgba(189, 162, 116, 0.05) 60%,
      transparent 100%
    );
    z-index: -1;
    transition: transform 0.5s var(--ease-vintage);
    transform: skewX(-20deg);
  }

  .nav-item:hover::before {
    transform: translateX(50%) skewX(-20deg);
  }

  .nav-item:hover,
  .nav-item.active {
    color: var(--color-brass-light);
  }

  /* Active item highlighted like the reference image paint stroke */
  .nav-item.active {
    color: var(--color-ink);
    background-color: var(--color-paper-dark);
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.03) 0%, rgba(0, 0, 0, 0.08) 100%),
      url("/assets/paper_texture.png");
    background-size: cover;
    box-shadow: 2px 4px 10px rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  .nav-item.active .nav-icon {
    color: var(--color-ink);
  }

  .nav-icon {
    display: flex;
    align-items: center;
    color: var(--color-brass-dark);
    transition: color 0.3s ease;
  }

  /* Footer Section */
  .sidebar-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .quote-container {
    width: 100%;
    position: relative;
  }

  .quote-text {
    font-family: var(--font-script);
    font-size: 1.6rem;
    color: var(--color-paper);
    line-height: 1.3;
    opacity: 0.9;
  }

  .quote-underline {
    width: 170px;
    height: 10px;
    color: var(--color-brass);
    opacity: 0.6;
    margin-top: -0.2rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-icon {
    color: var(--color-brass);
    opacity: 0.7;
    transition:
      opacity 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-icon:hover {
    color: var(--color-brass-light);
    opacity: 1;
    transform: translateY(-2px);
  }

  .audio-control {
    margin-top: 0.5rem;
  }

  .mute-btn {
    background: none;
    border: 1px solid var(--color-brass-dark);
    color: var(--color-brass);
    padding: 0.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.6;
  }

  .mute-btn:hover {
    opacity: 1;
    color: var(--color-brass-light);
    border-color: var(--color-brass-light);
    transform: scale(1.1);
  }

  /* Responsive Centering on smaller screens */
  @media (max-width: 1023px) {
    .sidebar-wrapper {
      height: auto;
      border-right: none;
      border-bottom: 1px solid rgba(189, 162, 116, 0.15);
      position: relative;
    }

    .sidebar-content {
      padding: 2.5rem 1.5rem 1.5rem 1.5rem;
      align-items: center;
      gap: 1.5rem;
      text-align: center;
    }

    .brand-section {
      align-items: center;
    }

    .mountain-doodle {
      width: 70px;
      margin-bottom: 0.25rem;
    }

    .logo-title {
      font-size: 2.5rem;
    }

    /* Menu Centered */
    .navigation-menu {
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .navigation-menu ul {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      max-width: 600px;
    }

    .navigation-menu li {
      width: auto;
    }

    .nav-item {
      padding: 0.5rem 1rem;
      font-size: 0.7rem;
      gap: 0.5rem;
    }

    .sidebar-footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      gap: 1rem;
      border-top: 1px dashed rgba(189, 162, 116, 0.15);
      padding-top: 1rem;
      margin-top: 0.5rem;
    }

    .quote-container {
      display: none; /* Hide quote on mobile to save vertical space */
    }

    .social-links {
      width: 100%;
      justify-content: center;
    }
  }
</style>
